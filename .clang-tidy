---
Checks: >
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-exception-escape,
  clang-analyzer-*,
  performance-*,
  -performance-enum-size,
  -performance-avoid-endl,
  modernize-use-override,
  modernize-use-nullptr

WarningsAsErrors: ''

# Lint project code under lib/* except vendored CLI11 (lib/cli/include) and nlohmann/json (lib/json/include).
HeaderFilterRegex: '^.*/(?:lib/(?!(?:cli|json)/include(?:/|$))|consensus|ledger|network|server|client|app)/.*'

FormatStyle: none
